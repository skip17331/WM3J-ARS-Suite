<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.jlog.controller.DxSpotController"
      styleClass="dx-panel" prefHeight="400">

    <HBox spacing="8" alignment="CENTER_LEFT" styleClass="dx-toolbar">
        <padding><Insets top="4" left="6" right="6" bottom="4"/></padding>
        <Button fx:id="btnClusterConnect"    text="Connect"    onAction="#doClusterConnect"/>
        <Button fx:id="btnClusterDisconnect" text="Disconnect" onAction="#doClusterDisconnect" disable="true"/>
        <Label  fx:id="lblClusterStatus"     styleClass="conn-status"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="%button.clear" onAction="#doClearSpots"/>
    </HBox>

    <TableView fx:id="spotTable" styleClass="spot-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colSpotter" text="%col.spotter"  prefWidth="90"/>
            <TableColumn fx:id="colDx"      text="%col.dx"       prefWidth="100"/>
            <TableColumn fx:id="colFreq"    text="%col.freq.khz" prefWidth="85"/>
            <TableColumn fx:id="colBand"    text="%col.band"     prefWidth="55"/>
            <TableColumn fx:id="colMode"    text="%col.mode"     prefWidth="55"/>
            <TableColumn fx:id="colCountry" text="%col.country"  prefWidth="120"/>
            <TableColumn fx:id="colComment" text="%col.comment"  prefWidth="200"/>
            <TableColumn fx:id="colTime"    text="%col.time"     prefWidth="55"/>
        </columns>
    </TableView>
</VBox>
