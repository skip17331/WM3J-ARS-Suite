<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.jlog.controller.ContestLogController"
            styleClass="main-window">

    <!-- ============================================================
         ROW 1: MENU BAR
         ============================================================ -->
    <top>
        <VBox>
            <MenuBar styleClass="menu-bar">
                <menus>
                    <Menu text="%menu.file">
                        <items>
                            <MenuItem text="%menu.file.new"    onAction="#menuNewDatabase"/>
                            <MenuItem text="%menu.file.backup" onAction="#menuBackupDatabase"/>
                            <SeparatorMenuItem/>
                            <MenuItem text="%menu.export.cabrillo" onAction="#menuExportCabrillo"/>
                        </items>
                    </Menu>
                    <Menu text="%menu.dx">
                        <items>
                            <MenuItem text="%menu.dx.show" onAction="#menuDxSpotting"/>
                        </items>
                    </Menu>
                    <Menu text="%menu.radio">
                        <items>
                            <MenuItem text="%menu.civ.connect"    onAction="#menuConnectCiv"/>
                            <MenuItem text="%menu.civ.disconnect" onAction="#menuDisconnectCiv"/>
                        </items>
                    </Menu>
                    <Menu text="%menu.setup">
                        <items>
                            <MenuItem text="%menu.setup.open" onAction="#menuSetup"/>
                        </items>
                    </Menu>
                    <Menu text="%menu.contest">
                        <items>
                            <MenuItem text="%menu.contest.setup"           onAction="#menuContestSetup"/>
                            <SeparatorMenuItem/>
                            <MenuItem text="%menu.contest.export.cabrillo" onAction="#menuExportCabrillo"/>
                        </items>
                    </Menu>
                </menus>
            </MenuBar>

            <!-- Status bar -->
            <HBox styleClass="clock-bar" spacing="16" alignment="CENTER_RIGHT">
                <padding><Insets right="12" top="2" bottom="2"/></padding>
                <Label fx:id="lblCivStatus" styleClass="civ-status" text="CI-V: —"/>
                <Label fx:id="lblStatus" styleClass="status-label"/>
            </HBox>

            <!-- ============================================================
                 ROW 2: DYNAMIC ENTRY BAR (built by controller)
                 ============================================================ -->
            <TitledPane text="%pane.entry" collapsible="false" styleClass="entry-pane">
                <VBox fx:id="entryBar" spacing="4">
                    <padding><Insets top="6" left="10" right="10" bottom="6"/></padding>
                </VBox>
            </TitledPane>

            <!-- Macro button bar -->
            <HBox fx:id="macroButtonBar" styleClass="macro-bar" spacing="4">
                <padding><Insets top="2" left="6" bottom="2"/></padding>
            </HBox>

            <!-- ============================================================
                 ROW 3: PLUGIN PANES
                 ============================================================ -->
            <HBox fx:id="row2PaneContainer" spacing="0" styleClass="plugin-pane-row"
                  minHeight="240" prefHeight="280">
                <!-- panes built dynamically by controller -->
            </HBox>
        </VBox>
    </top>

    <!-- ============================================================
         CENTER: QSO TABLE + DX SPOTTING
         ============================================================ -->
    <center>
        <SplitPane fx:id="mainSplitPane" orientation="VERTICAL">

            <!-- QSO Table -->
            <VBox styleClass="log-section">
                <HBox spacing="6" styleClass="table-toolbar">
                    <padding><Insets left="6" top="4" bottom="4"/></padding>
                    <Label text="%pane.log" styleClass="section-title"/>
                    <Button text="%button.prev" onAction="#doPageBack"/>
                    <Button text="%button.next" onAction="#doPageForward"/>
                    <Label fx:id="lblQsoCount" styleClass="qso-count"/>
                    <Label text=" | Score: "/>
                    <Label fx:id="lblScore" styleClass="score-value"/>
                    <Label text=" | Mults: "/>
                    <Label fx:id="lblMults"  styleClass="score-value"/>
                    <Label text=" | QSO/hr: "/>
                    <Label fx:id="lblQsoHour" styleClass="score-value"/>
                </HBox>
                <TableView fx:id="qsoTable" VBox.vgrow="ALWAYS" styleClass="qso-table">
                    <columns>
                        <TableColumn fx:id="colCall"       text="%col.callsign"  prefWidth="120"/>
                        <TableColumn fx:id="colTime"       text="%col.time"      prefWidth="70"/>
                        <TableColumn fx:id="colBand"       text="%col.band"      prefWidth="60"/>
                        <TableColumn fx:id="colMode"       text="%col.mode"      prefWidth="60"/>
                        <TableColumn fx:id="colSentSerial" text="%col.serial"    prefWidth="60"/>
                        <TableColumn fx:id="colExchange"   text="%col.exchange"  prefWidth="200"/>
                        <TableColumn fx:id="colPts"        text="%col.points"    prefWidth="50"/>
                        <TableColumn fx:id="colOp"         text="%col.operator"  prefWidth="80"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- DX Spotting -->
            <TitledPane fx:id="dxPane" text="%pane.dx" animated="false" styleClass="dx-pane">
                <fx:include source="DxSpot.fxml" fx:id="dxSpot"/>
            </TitledPane>

        </SplitPane>
    </center>
</BorderPane>
