<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback configuration for Ham Radio Hub.

    Appenders:
      CONSOLE  — colored output to stdout
      FILE     — rolling daily log file in ./logs/hub.log
-->
<configuration>

    <!-- ── Console appender ─────────────────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{30}) — %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Rolling file appender ────────────────────────────────────── -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/hub.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Daily rollover; keep 30 days of history -->
            <fileNamePattern>logs/hub-%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %logger{36} — %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Logger levels ────────────────────────────────────────────── -->

    <!-- Quieten noisy Jetty HTTP infrastructure -->
    <logger name="org.eclipse.jetty" level="WARN"/>

    <!-- Quieten Java-WebSocket library internals -->
    <logger name="org.java_websocket" level="WARN"/>

    <!-- Our application code at DEBUG in dev; change to INFO for production -->
    <logger name="com.hamradio.hub" level="DEBUG"/>

    <!-- ── Root ─────────────────────────────────────────────────────── -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
