  "statistics": ["qso_count","total_score","multipliers","qso_per_hour","sections_worked"],

  "cabrilloMapping": {
    "callsign":    "rcvd_callsign",
    "serial_sent": "sent_serial",
    "prec_sent":   "sent_precedence",
    "check_sent":  "sent_check",
    "sect_sent":   "sent_section",
    "serial_rcvd": "rcvd_serial",
    "precedence":  "rcvd_precedence",
    "check":       "rcvd_check",
    "section":     "rcvd_section",
