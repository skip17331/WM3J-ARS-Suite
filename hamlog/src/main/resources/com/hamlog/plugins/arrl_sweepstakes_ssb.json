    "EB","LAX","ORG","SB","SCV","SDG","SF","SJV","SV","PAC",
    "AZ","EWA","ID","MT","NV","OR","UT","WWA","WY",
    "CO","IA","IL","IN","KS","MI","MN","MO","ND","NE","OH","SD","WI",
